# FX Discovery — Environment Variables
# Copy this to .env and fill in your keys

# === REQUIRED ===
GEMINI_API_KEY=your_gemini_api_key_here
COMPANIES_HOUSE_API_KEY=your_companies_house_key_here

# === GEMINI MODEL ===
GEMINI_MODEL=gemini-2.0-flash

# === RATE LIMIT CONTROLS ===
# How many new events to analyse per run (Gemini calls = this number x 2)
# Start low if you're hitting 429s — increase once working
DISCOVERY_MAX_EVENTS=2

# How many companies to fetch per CH search term
# 20 is good — gives volume without hammering CH
DISCOVERY_MAX_COMPANIES_PER_TERM=20
